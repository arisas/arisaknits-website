
---
import "../styles/global.css";
import { Font } from "astro:assets";
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<Font cssVariable="--font-lato" />
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/arisaknits32-rounded.png" />
		<meta name="generator" content={Astro.generator} />
		<title>ArisaMakes</title>

	</head>
	<body>
		<h1 class="mt-20 mb-3 text-center text-6xl lowercase font-(family-name:--font-lato) font-bold">{title}</h1>
		<div>
		<p class="text-center text-3xl font-(family-name:--font-itim)">อริซ่า รวิวรรณ</p>
		</div>

		<slot />

	</body>

    <div class="bg-white">

	<div
        class="mx-auto max-w-screen-xl overflow-hidden px-4 py-12 sm:px-6 lg:px-8 lowercase"
      >
		<nav class="flex flex-wrap justify-center text-xl font-(family-name:--font-lato)">
          <div class="px-3 py-2">
			<a 
			href="/"
			class="leading-6 text-gray-500 hover:text-gray-900 hover:underline hover:underline-offset-2 hover:decoration-pink-500" 
			title="ArisaMakes - Home"
			>
			Home
			</a>
			</div>

			<div class="px-3 py-2">
			<a 
			href="/rowcounter"
			class="leading-6 text-gray-500 hover:text-gray-900 hover:decoration-indigo-300 hover:underline hover:underline-offset-2" 
			title="ArisaMakes Row Counter App"
			>
			Row Counter
			</a>
			</div>

			<div class="px-3 py-2">
			<a 
			href="/patterns/tgyhcrochetdoll"
			class="leading-6 text-gray-500 hover:text-gray-900 hover:decoration-amber-300 hover:underline hover:underline-offset-2" 
			title="Thank Goodness You're Here Crochet Doll Pattern"
			>
			Pattern
			</a>
			</div>	

			<div class="px-3 py-2">
			<a 
			href="/privacy"
			class="leading-6 text-gray-500 hover:text-gray-900 hover:decoration-violet-500 hover:underline hover:underline-offset-2" 
			title="ArisaMakes - Privacy Policy"
			>
			Privacy
			</a>
			</div>

		</nav>

	 <div class="mt-8 flex justify-center">

